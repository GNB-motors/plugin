## 8. Multi-Account Data Model

```mermaid
erDiagram
    USER["Backend User"] {
        string _id
        string name
        string role "OWNER|MANAGER|SUPER_ADMIN|DRIVER"
        string orgId
    }

    ACCOUNT["FleetEdgeAccount"] {
        string _id
        string orgId
        string source "EXTENSION"
        string externalAccountId "fleetId"
        string friendlyName
        string status "ACTIVE|AUTH_FAILED"
    }

    TOKEN["UserFleetEdgeToken"] {
        string _id
        string userId
        string fleetEdgeAccountId
        string encryptedToken "AES-256-GCM"
        datetime expiresAt
        string status "ACTIVE|NEEDS_REAUTH|REVOKED"
    }

    VEHICLE["Vehicle"] {
        string _id
        string registrationNumber
        string fleetEdgeAccountId
    }

    TASK["FuelComparisonTask"] {
        string _id
        string vehicleId
        string status "PENDING|IN_PROGRESS|COMPLETED|NO_DATA|FAILED"
        datetime nextRetryAt
    }

    USER ||--o{ TOKEN : "links"
    TOKEN }o--|| ACCOUNT : "belongs to"
    ACCOUNT ||--o{ VEHICLE : "tags"
    VEHICLE ||--o{ TASK : "generates"
```

